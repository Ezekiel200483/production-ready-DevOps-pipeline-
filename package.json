{
  "name": "nodejs-devops-app",
  "version": "1.0.0",
  "description": "Production-ready Node.js app with full DevOps pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:ci": "jest --forceExit --detectOpenHandles --ci --coverage",
    "lint": "eslint src/ tests/"
  },
  "keywords": ["nodejs", "devops", "docker", "redis"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "redis": "^4.6.13",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

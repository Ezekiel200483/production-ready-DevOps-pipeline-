# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to version control.

aws_region    = "us-east-1"
project_name  = "nodejs-app"
environment   = "staging"

container_image   = "ghcr.io/YOUR_GITHUB_USERNAME/nodejs-devops-app:latest"
ec2_instance_type = "t3.micro"

# Paste the output of: cat ~/.ssh/nodejs-app-key.pub
ec2_public_key = "ssh-rsa AAAA..."

# Your current IP — find it at whatismyip.com then add /32
ssh_allowed_cidr = "YOUR_IP/32"
